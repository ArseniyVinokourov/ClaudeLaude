# Create a bot via @BotFather in Telegram, paste the token here
BOT_TOKEN=123456789:AAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Your Telegram user ID (send /start to @userinfobot to find out)
OWNER_ID=123456789

# Root directory with your projects (bot will offer them in /new picker)
PROJECTS_DIR=/home/user/Projects

# Port for Claude Code hooks to POST events (default: 9853)
HOOK_PORT=9853

# Auto-update: check for new versions at startup and hourly (default: false)
# AUTO_UPDATE=false

# Policy when local code changes are detected during update: replace | merge
# replace = backup modified files and overwrite with new version
# merge = open a Claude session to guide you through merging
# AUTO_UPDATE_POLICY=replace

# ── Stickers ──────────────────────────────────────────────────────────────
# The bot can send Telegram stickers as occasional reactions. Out of the box
# it seeds one neutral official pack and is on. The catalog also grows from any
# sticker you send the bot (auto-learn).
#
# Disable sticker sending entirely (default: 1 = on):
# STICKERS_ENABLED=0
#
# Packs to seed at startup, comma-separated set names (the part after
# t.me/addstickers/). Overrides the built-in default. Empty = seed nothing and
# rely on auto-learn:
# STICKER_SETS=HotCherry
#
# Restrict which stickers the bot may send — comma-separated ids and/or ranges,
# e.g. s43-s63,s10. Useful to limit a mixed pack to one character. Empty = all:
# STICKER_ALLOW=
